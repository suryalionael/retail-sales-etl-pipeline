# Copy to .env and adjust for your runtime.
# Docker Compose / Airflow use POSTGRES_HOST=postgres (default below).
# Local CLI against exposed Postgres use POSTGRES_HOST=localhost and update DATABASE_URL.

POSTGRES_USER=retail
POSTGRES_PASSWORD=retail
POSTGRES_DB=retail_warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://retail:retail@postgres:5432/retail_warehouse

# Local CLI example (Postgres running via docker compose, port 5432 exposed):
# POSTGRES_HOST=localhost
# DATABASE_URL=postgresql+psycopg2://retail:retail@localhost:5432/retail_warehouse

AIRFLOW_UID=50000
DATASET_URL=https://archive.ics.uci.edu/static/public/352/online+retail.zip
DATASET_FILE=data/raw/online_retail.zip
RAW_EXTRACT_DIR=data/raw/online_retail
PROCESSED_DIR=data/processed
INCREMENTAL_STATE_FILE=data/processed/incremental_state.json
LOG_LEVEL=INFO
